# DIX VISION v42.2 Production Environment Configuration Template
# Copy this file to .env and fill in the actual values for your deployment

# ===========================================
# SYSTEM CONFIGURATION
# ===========================================
DIX_ENVIRONMENT=production
DIX_LOG_LEVEL=INFO
DIX_DEBUG=false
DIX_VERSION=42.2

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dix_vision
POSTGRES_USER=dix_user
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# Connection Pool Settings
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50

# Time-series Database (InfluxDB)
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
INFLUXDB_TOKEN=CHANGE_THIS_SECURE_TOKEN
INFLUXDB_ORG=dix_vision
INFLUXDB_BUCKET=market_data
INFLUXDB_ENABLED=false

# ===========================================
# CRYPTOGRAPHIC CONFIGURATION
# ===========================================

# Key Management
KEY_STORE_PATH=/secure/keys
ENCRYPTION_KEY_PATH=/secure/keys/master.key
KEY_ROTATION_DAYS=90

# Hardware Security Module (HSM)
ENABLE_HARDWARE_CRYPTOGRAPHY=false
HSM_PROVIDER=AWS_CLOUDHSM
HSM_PARTITION=
HSM_PIN=

# Cryptographic Algorithms
SIGNATURE_ALGORITHM=RSA-PSS-4096
HASH_ALGORITHM=SHA3-256
ENCRYPTION_ALGORITHM=AES-256-GCM
KEY_DERIVATION_ALGORITHM=PBKDF2-SHA256

# Fallback Configuration
ENABLE_CRYPTOGRAPHY_FALLBACK=true
FALLBACK_HASH_ALGORITHM=SHA-256
FALLBACK_SIGNATURE_ALGORITHM=HMAC-SHA256

# ===========================================
# TRADING CONFIGURATION
# ===========================================

# Risk Parameters
RISK_MAX_POSITION_SIZE=1000.0
RISK_MAX_PORTFOLIO_VALUE=1000000.0
RISK_MAX_DAILY_LOSS=0.02
RISK_MAX_DRAWDOWN=0.10
RISK_MAX_LEVERAGE=2.0
RISK_POSITION_SIZE_PCT=0.10
RISK_STOP_LOSS_PCT=0.05
RISK_TAKE_PROFIT_PCT=0.15

# Kelly Criterion Parameters
KELLY_REWARD_RISK_RATIO=3.0
KELLY_MAX_FRACTION=0.25
KELLY_MIN_FRACTION=0.01

# Order Configuration
ORDER_DEFAULT_TYPE=MARKET
ORDER_TIME_IN_FORCE=GTC
ORDER_SLIPPAGE_TOLERANCE=0.001

# Position Configuration
POSITION_AUTO_CLOSE=false
POSITION_CLOSE_TIME=UTC:23:59:59

# ===========================================
# DATA FEED CONFIGURATION
# ===========================================

# Primary Data Feed
DATA_FEED_PROVIDER=websocket
DATA_FEED_URL=wss://api.example.com/stream
DATA_FEED_API_KEY=CHANGE_THIS_API_KEY
DATA_FEED_API_SECRET=CHANGE_THIS_API_SECRET
DATA_FEED_TIMEOUT=30

# Backup Data Feed
DATA_FEED_BACKUP_PROVIDER=rest_api
DATA_FEED_BACKUP_URL=https://api.example.com/market
DATA_FEED_BACKUP_ENABLED=true

# Data Feed Configuration
DATA_FEED_SYMBOLS=BTC/USD,ETH/USD,AAPL,GOOGL,MSFT
DATA_FEED_UPDATE_INTERVAL=0.1
DATA_FEED_BUFFER_SIZE=50000

# Data Quality Configuration
DATA_QUALITY_ENABLED=true
DATA_QUALITY_STALE_THRESHOLD=5.0
DATA_QUALITY_MIN_CONFIDENCE=0.7

# ===========================================
# INTELLIGENCE ENGINE CONFIGURATION
# ===========================================

# Pattern Recognition
PATTERN_WINDOW_SIZE=500
PATTERN_UPDATE_INTERVAL=0.5
PATTERN_CACHE_ENABLED=true
PATTERN_CACHE_TTL=1800

# Risk Assessment
RISK_ASSESSMENT_ENABLED=true
RISK_ASSESSMENT_INTERVAL=1.0
VAR_CONFIDENCE_LEVEL=0.95
VAR_CONFIDENCE_LEVEL_99=0.99

# Decision Engine
DECISION_ENGINE_ENABLED=true
DECISION_ENGINE_INTERVAL=0.5
DECISION_CONFIDENCE_THRESHOLD=0.6
DECISION_ALTERNATIVE_ACTIONS_ENABLED=true

# Statistical Analysis
STATISTICAL_ANALYSIS_ENABLED=true
RSI_PERIOD=14
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9
SMA_SHORT_PERIOD=10
SMA_LONG_PERIOD=30

# ===========================================
# MONITORING CONFIGURATION
# ===========================================

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=true
PERFORMANCE_SAMPLE_INTERVAL=1.0
PERFORMANCE_HISTORY_SIZE=1000

# Alerting
ALERTING_ENABLED=true
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SLACK_ENABLED=false
ALERT_SLACK_WEBHOOK=
ALERT_PAGERDUTY_ENABLED=false
ALERT_PAGERDUTY_API_KEY=

# Metrics Export
METRICS_EXPORT_ENABLED=false
METRICS_EXPORT_INTERVAL=60
METRICS_EXPORT_FORMAT=prometheus
METRICS_EXPORT_URL=http://localhost:9090/metrics

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

# Log Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=/var/log/dix_vision/dix_vision.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10
LOG_COMPRESSION=true

# Component Log Levels
LOG_CRYPTO_LEVEL=INFO
LOG_INTELLIGENCE_LEVEL=INFO
LOG_TRADING_LEVEL=INFO
LOG_DATA_LEVEL=DEBUG

# Structured Logging
STRUCTURED_LOGGING_ENABLED=true
LOG_REQUEST_ID_ENABLED=true
LOG_USER_ID_ENABLED=true
LOG_TIMING_ENABLED=true

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# Authentication
AUTH_ENABLED=false
AUTH_METHOD=jwt
AUTH_SECRET_KEY=CHANGE_THIS_SECRET_KEY
AUTH_TOKEN_EXPIRY=3600
AUTH_REFRESH_EXPIRY=86400

# Multi-Factor Authentication
MFA_ENABLED=false
MFA_METHOD=totp
MFA_ISSUER=DIX_VISION

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# IP Whitelisting
IP_WHITELIST_ENABLED=false
IP_WHITELIST_RANGES=10.0.0.0/8,192.168.0.0/16

# TLS Configuration
TLS_ENABLED=false
TLS_CERT_PATH=/etc/ssl/certs/dix_vision.crt
TLS_KEY_PATH=/etc/ssl/private/dix_vision.key
TLS_CA_PATH=/etc/ssl/certs/ca.crt
TLS_MIN_VERSION=1.2
TLS_CIPHERS=ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384

# ===========================================
# NETWORK CONFIGURATION
# ===========================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
API_TLS_PORT=8443
API_WORKERS=4

# WebSocket Configuration
WS_ENABLED=true
WS_PORT=8081
WS_TLS_PORT=8444
WS_MAX_CONNECTIONS=1000
WS_MESSAGE_SIZE_LIMIT=1048576

# gRPC Configuration (if enabled)
GRPC_ENABLED=false
GRPC_PORT=50051
GRPC_TLS_PORT=50052

# ===========================================
# OPERATIONAL CONFIGURATION
# ===========================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/dix_vision
BACKUP_COMPRESSION=true

# Maintenance Windows
MAINTENANCE_MODE=false
MAINTENANCE_WINDOW_START=UTC:02:00
MAINTENANCE_WINDOW_END=UTC:04:00
MAINTENANCE_ALERT_EMAIL=

# Shutdown Configuration
GRACEFUL_SHUTDOWN_TIMEOUT=60
FORCE_SHUTDOWN_AFTER_TIMEOUT=true
EMERGENCY_SHUTDOWN_ENABLED=true

# ===========================================
# COMPLIANCE CONFIGURATION
# ===========================================

# Audit Logging
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_PATH=/var/log/dix_vision/audit.log
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_IMMEDIATE_FLUSH=true

# Order Audit Trail
ORDER_AUDIT_ENABLED=true
ORDER_AUDIT_RETENTION_DAYS=365
ORDER_AUDIT_IMMUTABLE=true

# Position Reporting
POSITION_REPORTING_ENABLED=true
POSITION_REPORTING_INTERVAL=3600
POSITION_REPORTING_RETENTION_DAYS=365

# Data Retention
DATA_RETENTION_DAYS=90
DATA_RETENTION_ARCHIVE=true
DATA_RETENTION_ARCHIVE_PATH=/var/archive/dix_vision

# ===========================================
# DEVELOPMENT/TESTING FLAGS
# ===========================================

# Environment-Specific Flags
DEVELOPMENT_MODE=false
TESTING_MODE=false
STAGING_MODE=false

# Feature Flags
FEATURE_EXPERIMENTAL_ALGORITHMS=false
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_MACHINE_LEARNING=false
FEATURE_BLOCKCHAIN_INTEGRATION=false

# Debugging Flags
DEBUG_CRYPTO_OPERATIONS=false
DEBUG_INTELLIGENCE_ENGINE=false
DEBUG_TRADING_DECISIONS=false
DEBUG_DATA_PIPELINE=false

# ===========================================
# CLUSTER CONFIGURATION (for distributed deployment)
# ===========================================

# Cluster Configuration
CLUSTER_MODE=false
CLUSTER_SIZE=1
CLUSTER_NODE_ID=1
CLUSTER_COORDINATOR_ENABLED=false

# Service Discovery
SERVICE_DISCOVERY_ENABLED=false
SERVICE_DISCOVERY_METHOD=consul
CONSUL_HOST=localhost
CONSUL_PORT=8500

# Load Balancing
LOAD_BALANCING_ENABLED=false
LOAD_BALANCING_METHOD=round_robin
LOAD_BALANCER_HEALTH_CHECK=true

# ===========================================
# THIRD-PARTY INTEGRATIONS
# ===========================================

# Notification Services
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_SLACK_ENABLED=false
NOTIFICATION_PAGERDUTY_ENABLED=false

# External Services
EXTERNAL_ANALYTICS_ENABLED=false
EXTERNAL_ANALYTICS_URL=
EXTERNAL_MONITORING_ENABLED=false
EXTERNAL_MONITORING_URL=

# ===========================================
# MISCELLANEOUS
# ===========================================

# Timezone
TIMEZONE=UTC

# Locale
LOCALE=en_US.UTF-8

# Character Encoding
ENCODING=utf-8

# Process Configuration
PROCESS_WORKERS=4
PROCESS_THREADS=8
PROCESS_MAX_MEMORY=4096

# File Upload Configuration
FILE_UPLOAD_ENABLED=false
FILE_UPLOAD_MAX_SIZE=10485760
FILE_UPLOAD_ALLOWED_TYPES=csv,json