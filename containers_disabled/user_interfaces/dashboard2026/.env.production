# DIX VISION v42.2 - Dashboard Production Configuration
# Production environment configuration for Dashboard2026

# API Configuration
VITE_API_BASE=https://api.dixvision.v42.2
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# WebSocket Configuration
VITE_WS_BASE=wss://api.dixvision.v42.2
VITE_WS_RECONNECT_INTERVAL=5000
VITE_WS_MAX_RECONNECT_ATTEMPTS=10

# Authentication Configuration
VITE_AUTH_ENABLED=true
VITE_AUTH_PROVIDER=oauth2
VITE_AUTH_TOKEN_EXPIRY=3600

# Dashboard Configuration
VITE_DASHBOARD_TITLE="DIX VISION v42.2 - Cognitive Trading Dashboard"
VITE_DASHBOARD_THEME=dark
VITE_DASHBOARD_AUTO_REFRESH=15000
VITE_DASHBOARD_HEALTH_CHECK_INTERVAL=10000

# Plugin System Configuration
VITE_PLUGIN_MARKETPLACE_ENABLED=true
VITE_PLUGIN_AUTO_UPDATE=false
VITE_PLUGIN_HEALTH_MONITORING=true

# Feature Flags
VITE_FEATURE_COGNITIVE_CHAT=true
VITE_FEATURE_WORLD_INDICATOR_COORDINATOR=true
VITE_FEATURE_INDIRA_INTELLIGENCE=true
VITE_FEATURE_DYON_LEARNING=true
VITE_FEATURE_MEMECOIN_ANALYSIS=true

# Performance Configuration
VITE_BUNDLE_ANALYZER=false
VITE_SOURCE_MAP=false
VITE_MINIFY=true

# Logging Configuration
VITE_LOG_LEVEL=error
VITE_LOG_TO_CONSOLE=false
VITE_LOG_TO_REMOTE=true

# Monitoring Configuration
VITE_MONITORING_ENABLED=true
VITE_MONITORING_ENDPOINT=https://monitoring.dixvision.v42.2
VITE_ERROR_TRACKING_ENABLED=true