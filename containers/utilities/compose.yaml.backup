    container_name: dix-beautifulsoup4-service
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.5'
          memory: 256M
    environment:
    - BEAUTIFULSOUP4_LOG_LEVEL=INFO
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-beautifulsoup4:latest
    networks:
    - dixvision-network
    ports:
    - 9166:9166
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/beautifulsoup4/config:/app/config
    - ./containers/github_repos/beautifulsoup4/data:/app/data
    - ./containers/github_repos/beautifulsoup4/logs:/app/logs
  blackbox-service:
    build:
      context: ./containers/github_repos/blackbox
      dockerfile: Dockerfile
    container_name: dix-blackbox-service
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.5'
          memory: 256M
    environment:
    - BLACKBOX_LOG_LEVEL=INFO
    - BLACKBOX_PERMISSION_LEVEL=READ_ONLY
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-blackbox:latest
    networks:
    - dixvision-network
    ports:
    - 9134:9134
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/blackbox/config:/app/config
    - ./containers/github_repos/blackbox/data:/app/data
    - ./containers/github_repos/blackbox/logs:/app/logs
    - ./containers/github_repos/blackbox/probes:/app/probes
  ccxt-service:
    build:
      context: ./containers/github_repos/ccxt
      dockerfile: Dockerfile
    container_name: dix-ccxt-service
    depends_on:
    - redis-service
    - postgresql-service
    - prometheus-service
    deploy:
      resources:
        limits:
          cpus: '1.5'
          memory: 1G
        reservations:
          cpus: '0.5'
          memory: 512M
    environment:
    - CCXT_LOG_LEVEL=INFO
    - CCXT_RATE_LIMIT=true
    - CCXT_PERMISSION_LEVEL=READ_ONLY
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-ccxt:latest
    networks:
    - dixvision-network
    ports:
    - 8080:8080
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/ccxt/config:/app/config
    - ./containers/github_repos/ccxt/data:/app/data
    - ./containers/github_repos/ccxt/logs:/app/logs
  celery-enhanced-service:
    build:
      context: ./containers/github_repos/celery-enhanced
      dockerfile: Dockerfile
    container_name: dix-celery-enhanced-service
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.5'
          memory: 256M
    environment:
    - CELERY_ENHANCED_LOG_LEVEL=INFO
    - CELERY_ENHANCED_PERMISSION_LEVEL=READ_ONLY
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-celery-enhanced:latest
    networks:
    - dixvision-network
    ports:
    - 9138:9138
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/celery-enhanced/config:/app/config
    - ./containers/github_repos/celery-enhanced/data:/app/data
    - ./containers/github_repos/celery-enhanced/logs:/app/logs
    - ./containers/github_repos/celery-enhanced/tasks:/app/tasks
  celery-service:
    build:
      context: ./containers/github_repos/celery
      dockerfile: Dockerfile
    container_name: dix-celery-service
    depends_on:
    - redis-service
    - postgresql-service
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 1G
        reservations:
          cpus: '1.0'
          memory: 512M
    environment:
    - CELERY_LOG_LEVEL=INFO
    - CELERY_PERMISSION_LEVEL=READ_ONLY
    - CELERY_BROKER_URL=redis://redis-service:6379/0
    - CELERY_RESULT_BACKEND=redis://redis-service:6379/0
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-celery:latest
    networks:
    - dixvision-network
    ports:
    - 5555:5555
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/celery/config:/app/config
    - ./containers/github_repos/celery/data:/app/data
    - ./containers/github_repos/celery/logs:/app/logs
    - ./containers/github_repos/celery/tasks:/app/tasks
