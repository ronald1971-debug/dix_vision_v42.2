      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-apache-beam:latest
    networks:
    - dixvision-network
    ports:
    - 9163:9163
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/apache-beam/config:/app/config
    - ./containers/github_repos/apache-beam/data:/app/data
    - ./containers/github_repos/apache-beam/logs:/app/logs
  argon-service:
    build:
      context: ./containers/github_repos/argon
      dockerfile: Dockerfile
    container_name: dix-argon-service
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.5'
          memory: 256M
    environment:
    - ARGON_LOG_LEVEL=INFO
    healthcheck:
      interval: 30s
