  desktop-agent-service:
    build:
      context: ./desktop_agent
      dockerfile: Dockerfile
    container_name: dix-desktop-agent-service
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
        reservations:
          cpus: '1.0'
          memory: 1G
    environment:
    - DESKTOP_AGENT_LOG_LEVEL=INFO
    - DASHBOARD_URL=http://dashboard2026-service:9003
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - -c
      - import requests; requests.get("http://localhost:9186/health")
      timeout: 10s
    image: dix-desktop-agent:latest
    networks:
    - dixvision-network
    ports:
    - 9186:9186
    restart: unless-stopped
    volumes:
    - ./desktop_agent/app_data:/app/data
    - ./desktop_agent/logs:/app/logs
    - ./desktop_agent/config:/app/config
    - ./desktop_agent/learning:/app/learning
