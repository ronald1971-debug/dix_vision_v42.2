networks:
  dixvision-network:
    driver: bridge
services:
  aiohttp-service:
    build:
      context: ./containers/github_repos/aiohttp
      dockerfile: Dockerfile
    container_name: dix-aiohttp-service
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.5'
          memory: 256M
    environment:
    - AIOHTTP_LOG_LEVEL=INFO
    - AIOHTTP_PERMISSION_LEVEL=READ_ONLY
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-aiohttp:latest
    networks:
    - dixvision-network
    ports:
    - 9140:9140
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/aiohttp/config:/app/config
    - ./containers/github_repos/aiohttp/data:/app/data
    - ./containers/github_repos/aiohttp/logs:/app/logs
    - ./containers/github_repos/aiohttp/applications:/app/applications
  airflow-service:
    build:
      context: ./containers/github_repos/airflow
      dockerfile: Dockerfile
    container_name: dix-airflow-service
    deploy:
      resources:
        limits:
          cpus: '1.5'
          memory: 1G
        reservations:
          cpus: '0.5'
          memory: 512M
    environment:
    - AIRFLOW_LOG_LEVEL=INFO
    - AIRFLOW_PERMISSION_LEVEL=READ_ONLY
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - python
      - /app/health_check.py
      timeout: 10s
    image: dix-airflow:latest
    networks:
    - dixvision-network
    ports:
    - 9117:9117
    restart: unless-stopped
    volumes:
    - ./containers/github_repos/airflow/config:/app/config
    - ./containers/github_repos/airflow/data:/app/data
    - ./containers/github_repos/airflow/logs:/app/logs
    - ./containers/github_repos/airflow/dags:/app/dags"
    - ./containers/github_repos/airflow/plugins:/app/plugins
  apache-beam-service:
    build:
      context: ./containers/github_repos/apache-beam
      dockerfile: Dockerfile
    container_name: dix-apache-beam-service
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
