    - ./containers/github_repos/discordbot/messages:/app/messages
  dixvisiondashboard2026:
    build:
      context: dashboard2026
      dockerfile: ./Dockerfile
    depends_on:
    - redis-service
    environment:
      NODE_ENV: production
      REDIS_URL: redis://redis-service:6379
    image: dixvisiondashboard2026
    networks:
    - dixvision-network
