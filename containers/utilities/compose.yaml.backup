    - ./containers/github_repos/websockets/data:/app/data
    - ./containers/github_repos/websockets/logs:/app/logs
    - ./containers/github_repos/websockets/connections:/app/connections
volumes:
  grafana-data: null
  postgres-data: null
  prometheus-data: null
  redis-data: null
