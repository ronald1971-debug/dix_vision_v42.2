# Node
node_modules/
dist/
.vite/
.tsbuild/
*.tsbuildinfo
*.log
.pnpm-debug.log*

# Rust / Tauri
target/
src-tauri/target/
src-tauri/gen/
src-tauri/cargo_output.txt

# Models (downloaded on first run, never committed)
models/
*.gguf
*.onnx
*.bin

# Bundled Piper TTS binary (fetched by scripts/fetch-piper.mjs per target)
src-tauri/binaries/*
!src-tauri/binaries/piper
src-tauri/binaries/piper/*
!src-tauri/binaries/piper/.keep

# Env / secrets
.env
.env.local
.env.*.local
# Tauri updater signing keys — never commit these
*.key
*.key.pub
~/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
!.vscode/extensions.json
.idea/
