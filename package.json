{
  "name": "dix-vision-monorepo",
  "version": "42.2.0",
  "private": true,
  "description": "DIX VISION - Cognitive OS + Dual-Domain Architecture",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=...^[HEAD] && changeset publish",
    "validate": "node scripts/validate-dependency-rules.js && node scripts/validate-boundary-rules.js",
    "validate:deps": "node scripts/validate-dependency-rules.js",
    "validate:boundaries": "node scripts/validate-boundary-rules.js"
  },
  "devDependencies": {
    "turbo": "^1.11.0",
    "prettier": "^3.1.0",
    "@changesets/cli": "^2.27.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@9.6.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}