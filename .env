# DIX VISION v42.2 - Environment Configuration
# Add your API keys here to enable real LLM functionality

# OpenRouter API Key (primary provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API Key (alternative provider)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (primary provider for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pinecone API Key (for vector database - optional)
PINECONE_API_KEY=your_pinecone_api_key_here

# Neo4j Configuration (for knowledge graph - optional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# System Configuration
COGNITIVE_MODE=active
LLM_PROVIDER=openrouter
