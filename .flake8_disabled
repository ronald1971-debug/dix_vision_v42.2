[flake8]
max-line-length = 100
max-complexity = 10
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    containers/github_repos,
    *.egg-info
ignore = 
    E203,  # whitespace before ':' (conflicts with black)
    W503,  # line break before binary operator (conflicts with black)
per-file-ignores =
    __init__.py:F401  # allow unused imports in __init__.py
    tests/*:S101  # allow assert in tests

# Error codes
# E - errors
# W - warnings
# F - pyflakes
# C - mccabe complexity
# S - bandit security
# N - pep8 naming