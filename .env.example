# DIX VISION v42.2 - Backend Configuration Template
# Copy this file to .env and configure for your environment

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
WORKERS=4

# Database Configuration
DATABASE_URL=sqlite:///./data/ledger.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration (for caching and session management)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=7200

# Cognitive Engine Configuration
COGNITIVE_ENGINE_ENABLED=true
COGNITIVE_ENGINE_TIMEOUT=30
COGNITIVE_ENGINE_MAX_RETRIES=3

# Plugin Configuration
PLUGIN_REGISTRY_PATH=registry/plugins.yaml
PLUGIN_HOT_RELOAD=true
PLUGIN_LIFECYCLE_CHECK_INTERVAL=60

# Authentication Configuration
AUTH_ENABLED=true
AUTH_SECRET_KEY=your-secret-key-here
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRY=3600

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# WebSocket Configuration
WS_ENABLED=true
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS=100

# Logging Configuration
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/dixvision.log
LOG_ROTATION=100MB
LOG_RETENTION=30days

# Monitoring Configuration
MONITORING_ENABLED=true
MONITORING_INTERVAL=30
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=60

# Market Data Configuration
MARKET_DATA_ENABLED=true
MARKET_DATA_TIMEOUT=10
MARKET_DATA_RETRY_ATTEMPTS=3
MARKET_DATA_BACKOFF_FACTOR=2

# Governance Configuration
GOVERNANCE_ENABLED=true
GOVERNANCE_AUTHORITY_GRAPH_ENABLED=true
GOVERNANCE_AUDIT_ENABLED=true
GOVERNANCE_MODE=MANUAL

# World Indicator Configuration
WORLD_INDICATOR_ENABLED=true
WORLD_INDICATOR_INTEGRATION_MODE=HYBRID_DECISION_FUSION
WORLD_INDICATOR_TIMEOUT=15

# Dashboard Configuration
DASHBOARD_ENABLED=true
DASHBOARD_PATH=/dash2
DASHBOARD_STATIC_PATH=dashboard2026/dist

# Time Source Configuration
TIME_SOURCE_TYPE=WALLCLOCK
TIME_SOURCE_TIMEZONE=UTC

# Security Configuration
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Feature Flags
FEATURE_COGNITIVE_CHAT=true
FEATURE_MEMECOIN_ANALYSIS=true
FEATURE_CROSS_PLATFORM=true
FEATURE_PLUGIN_MARKETPLACE=true