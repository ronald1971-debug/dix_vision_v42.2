{
    "git.ignoreLimitWarning": true,
    "git.enabled": true,
    "git.path": "git",
    "git.autofetch": false,
    "git.confirmSync": false,
    "git.enableSmartCommit": false,
    "git.postCommitCommand": "none",
    "scm.defaultViewMode": "tree",
    "scm.inputFontSize": 14,
    "scm.alwaysShowActions": false,
    "scm.alwaysShowRepositories": false,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.hg/store/**": true,
        "**/cache/**": true,
        "**/logs/**": true,
        "**/__pycache__/**": true
    },
    "search.exclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/cache/**": true,
        "**/logs/**": true,
        "**/temp_extract/**": true,
        "**/.pytest_cache/**": true,
        "**/__pycache__/**": true,
        "**/containers/**/node_modules/**": true,
        "**/*.pyc": true
    },
    "editor.largeFileOptimizations": true,
    "telemetry.telemetryLevel": "off",
    "extensions.autoUpdate": false,
    "extensions.autoCheckUpdates": false,
    "extensions.ignoreRecommendations": true,
    "extensions.showRecommendationsOnlyOnDemand": true,
    "workbench.editor.enabled": true,
    "window.restoreWindows": "preserve",
    "window.restoreFullscreen": false,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/cache": true,
        "**/logs": true,
        "**/temp_extract": true
    },
    "editor.suggest.showStatusBar": true,
    "editor.quickSuggestions": "on",
    "editor.parameterHints": "on",
    "editor.autoClosingBrackets": "languageDefined",
    "editor.minimap.enabled": true,
    "editor.renderWhitespace": "selection",
    "editor.renderLineHighlight": "all",
    "editor.occurrencesHighlight": "multiFile",
    "editor.selectionHighlight": true,
    "editor.folding": true,
    "editor.stickyScroll.enabled": true,
    "breadcrumbs.enabled": true,
    "workbench.colorTheme": "Default High Contrast",
    "workbench.statusBar.visible": true,
    "npm.enableRunFromFolder": false,
    "js/ts.suggestionActions.enabled": false,
    "typescript.tsc.autoDetect": "off",
    "javascript.tsc.autoDetect": "off",
    "git.autorefresh": false,
    "terminal.integrated.enablePersistentSessions": false,
    "window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${profileName}",
    "window.newWindowDimensions": "maximized"
}